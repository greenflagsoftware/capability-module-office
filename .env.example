# Postgres connection for the Office module's indexing database.
# The docker-compose.yml defaults OFFICE_DB_PASSWORD to "office_module_dev"
# if not set. Supply a different value here for local dev.
OFFICE_DB_PASSWORD=office_module_dev

# Embedding provider selection — swaps the vector-embedding backend without
# any code change. Defaults to "openai" if unset. See EmbeddingProviderFactory.
# Supported values: "openai", "openrouter".
# EMBEDDING_PROVIDER=openai

# OpenAI API key for generating vector embeddings (text-embedding-3-small).
# Required when running `index build` with --embed (default true), for the
# default "openai" provider.
# Never logged or exposed in output.
OPENAI_API_KEY=sk-your-key-here

# --- OpenRouter alternative (set EMBEDDING_PROVIDER=openrouter to use) ---
# Routes embedding calls through OpenRouter's OpenAI-compatible /embeddings
# endpoint instead of OpenAI directly — useful if you have an OpenRouter key
# but no direct OpenAI API key. Get a key at https://openrouter.ai/keys.
# Never logged or exposed in output.
# OPENROUTER_API_KEY=sk-or-your-key-here

# Model OpenRouter routes the embedding request to. Defaults to
# "openai/text-embedding-3-small" if unset, which keeps the same
# 1536-dimension output this module's schema already expects — changing
# this to a model with different dimensionality requires a schema migration
# and a full re-index (see OpenRouterEmbeddingProvider).
# OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Maximum upload size in bytes for the `upload` command. Defaults to 52428800 (50 MB).
# OFFICE_MAX_UPLOAD_SIZE=52428800
