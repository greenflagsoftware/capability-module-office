# Postgres connection for the Office module's indexing database.
# The docker-compose.yml defaults OFFICE_DB_PASSWORD to "office_module_dev"
# if not set. Supply a different value here for local dev.
OFFICE_DB_PASSWORD=office_module_dev

# Embedding provider selection — swaps the vector-embedding backend without
# any code change. Defaults to "openai" if unset. See EmbeddingProviderFactory.
# EMBEDDING_PROVIDER=openai

# OpenAI API key for generating vector embeddings (text-embedding-3-small).
# Required when running `index build` with --embed (default true), for the
# default "openai" provider.
# Never logged or exposed in output.
OPENAI_API_KEY=sk-your-key-here

# Maximum upload size in bytes for the `upload` command. Defaults to 52428800 (50 MB).
# OFFICE_MAX_UPLOAD_SIZE=52428800
